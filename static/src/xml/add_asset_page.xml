<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="kio_asset_management.AddAssetPage" owl="1">
        <section class="kio_add_asset_page">
            <header class="kio_add_header">
                <button class="kio_list_back" type="button" t-on-click="closeAddAsset" aria-label="Back">
                    <i class="fa fa-arrow-left"/>
                </button>
                <div class="kio_list_title_block">
                    <h1 t-esc="state.assetFormMode === &quot;edit&quot; ? &quot;Edit Asset&quot; : &quot;Add New Asset&quot;"/>
                    <nav class="kio_breadcrumb" aria-label="Breadcrumb">
                        <button type="button" t-on-click="openDashboard">Dashboard</button>
                        <i class="fa fa-angle-right"/>
                        <span>Assets</span>
                        <i class="fa fa-angle-right"/>
                        <strong t-esc="state.assetFormMode === &quot;edit&quot; ? &quot;Edit Asset&quot; : &quot;Add New Asset&quot;"/>
                    </nav>
                </div>
                <!-- <div class="kio_asset_header_tools kio_list_tools">
                    <label class="kio_asset_search kio_list_search">
                        <i class="fa fa-search"/>
                        <input type="search" placeholder="Search assets..."/>
                    </label>
                    <button class="kio_asset_icon_btn" type="button" aria-label="Notifications"><i class="fa fa-bell-o"/><span class="kio_asset_badge">8</span></button>
                    <button class="kio_asset_icon_btn" type="button" aria-label="Messages"><i class="fa fa-envelope-o"/><span class="kio_asset_badge">5</span></button>
                    <button class="kio_asset_avatar" type="button" aria-label="User profile"><span>AU</span></button>
                </div> -->
            </header>

            <main class="kio_add_main">
                <div class="kio_add_actions">
                    <button class="kio_cancel_btn" type="button" t-on-click="closeAddAsset">Cancel</button>
                    <button class="kio_save_btn" type="button" t-att-disabled="state.isSavingAsset" t-on-click="saveAsset"><i class="fa fa-floppy-o"/> Save Asset</button>
                </div>

                <div t-if="state.saveAssetError" class="alert alert-danger" role="alert" t-esc="state.saveAssetError"/>

                <section class="kio_add_top_grid">
                    <article class="kio_form_card kio_basic_card">
                        <div class="kio_form_card_header"><i class="fa fa-list-alt"/><h2>Basic Information</h2></div>
                        <div class="kio_form_grid kio_form_grid_4">
                            <label class="kio_form_field"><span>Asset Code <b>*</b></span><input t-att-value="addAssetForm.assetCode" readonly="readonly"/></label>
                            <label class="kio_form_field"><span>Asset Name <b>*</b></span><input t-att-value="addAssetForm.assetName" t-on-input="(ev) => this.onAssetFormInput('assetName', ev)"/></label>
                            <label class="kio_form_field"><span>Asset Category <b>*</b></span><input t-if="state.assetFormMode === &quot;edit&quot;" t-att-value="addAssetForm.category" readonly="readonly"/><select t-else="" t-att-value="addAssetForm.categoryId || &quot;&quot;" t-on-change="onAssetCategoryChange"><option value="" t-att-selected="!addAssetForm.categoryId" t-esc="addAssetForm.category || 'Select Category'"/><t t-foreach="categoryOptions" t-as="category" t-key="category.id"><option t-att-value="category.idValue" t-att-selected="(addAssetForm.categoryId || &quot;&quot;) === category.idValue" t-esc="category.label"/></t></select></label>
                            <label class="kio_form_field"><span>Brand / Model</span><select t-att-value="addAssetForm.brandModel" t-on-change="(ev) => this.onAssetFormInput('brandModel', ev)"><option t-att-value="addAssetForm.brandModel" t-esc="addAssetForm.brandModel"/></select></label>
                            <label class="kio_form_field"><span>Serial Number <b>*</b></span><input t-att-value="addAssetForm.serialNumber" t-on-input="(ev) => this.onAssetFormInput('serialNumber', ev)"/></label>
                            <label class="kio_form_field"><span>Barcode / QR Code</span><input t-att-value="addAssetForm.barcode" t-on-input="(ev) => this.onAssetFormInput('barcode', ev)"/></label>
                            <label class="kio_form_field"><span>Status <b>*</b></span><select t-att-value="addAssetForm.status" t-on-change="(ev) => this.onAssetFormInput('status', ev)"><option t-att-value="addAssetForm.status" t-esc="addAssetForm.status"/></select></label>
                            <label class="kio_form_field"><span>Asset Type <b>*</b></span><select t-att-value="addAssetForm.assetType" t-on-change="(ev) => this.onAssetFormInput('assetType', ev)"><option t-att-value="addAssetForm.assetType" t-esc="addAssetForm.assetType"/></select></label>
                            <label class="kio_form_field"><span>Purchase Date <b>*</b></span><div class="kio_input_icon"><input type="date" t-att-value="addAssetForm.purchaseDate" t-on-click="openAssetDatePicker" t-on-input="(ev) => this.onAssetDateInput('purchaseDate', ev)" t-on-change="(ev) => this.onAssetDateInput('purchaseDate', ev)"/><i class="fa fa-calendar" t-on-click="openAssetDatePicker"/></div></label>
                            <label class="kio_form_field"><span>Purchase Price (৳) <b>*</b></span><input t-att-value="addAssetForm.purchasePrice" t-on-input="(ev) => this.onAssetFormInput('purchasePrice', ev)"/></label>
                            <label class="kio_form_field"><span>Warranty Expiry Date</span><div class="kio_input_icon"><input type="date" t-att-value="addAssetForm.warrantyExpiry" t-on-click="openAssetDatePicker" t-on-input="(ev) => this.onAssetDateInput('warrantyExpiry', ev)" t-on-change="(ev) => this.onAssetDateInput('warrantyExpiry', ev)"/><i class="fa fa-calendar" t-on-click="openAssetDatePicker"/></div></label>
                            <label class="kio_form_field"><span>Condition <b>*</b></span><select t-att-value="addAssetForm.conditionId || &quot;&quot;" t-on-change="onAssetConditionChange"><option value="" t-att-selected="!addAssetForm.conditionId">Select Condition</option><t t-foreach="state.conditions" t-as="condition" t-key="condition.id"><option t-att-value="condition.idValue" t-att-selected="(addAssetForm.conditionId || &quot;&quot;) === condition.idValue" t-esc="condition.name"/></t></select></label>
                            <label class="kio_form_field kio_span_4"><span>Description</span><textarea t-att-value="addAssetForm.description" t-on-input="(ev) => this.onAssetFormInput('description', ev)"><t t-esc="addAssetForm.description"/></textarea></label>
                        </div>
                    </article>

                    <article class="kio_form_card kio_image_card">
                        <div class="kio_form_card_header"><i class="fa fa-picture-o"/><h2>Asset Image</h2></div>
                        <label class="kio_upload_area">
                            <div class="kio_upload_preview"><img t-if="addAssetForm.imagePreviewUrl" t-att-src="addAssetForm.imagePreviewUrl" alt="Asset image"/><i t-else="" class="fa fa-laptop"/><span><i class="fa fa-camera"/></span></div>
                            <p>Click to upload or drag and drop</p>
                            <small>PNG, JPG up to 5MB</small>
                            <input class="kio_upload_file" type="file" accept="image/*" t-on-change="onAssetImageChange"/>
                        </label>
                    </article>
                </section>

                <section class="kio_form_three_grid">
                    <article class="kio_form_card">
                        <div class="kio_form_card_header"><i class="fa fa-map-marker"/><h2>Location Information</h2></div>
                        <div class="kio_form_grid kio_form_grid_2">
                            <label class="kio_form_field"><span>Location <b>*</b></span><select t-att-value="addAssetForm.locationId || &quot;&quot;" t-on-change="onAssetLocationChange"><option value="" t-att-selected="!addAssetForm.locationId">Select Location</option><t t-foreach="locationOptions" t-as="location" t-key="location.id"><option t-att-value="location.idValue" t-att-selected="(addAssetForm.locationId || &quot;&quot;) === location.idValue" t-esc="location.name"/></t></select></label>
                            <label class="kio_form_field"><span>Building / Floor</span><input t-att-value="addAssetForm.buildingFloor" t-on-input="(ev) => this.onAssetFormInput('buildingFloor', ev)"/></label>
                            <label class="kio_form_field"><span>Room / Area</span><input t-att-value="addAssetForm.roomArea" t-on-input="(ev) => this.onAssetFormInput('roomArea', ev)"/></label>
                            <label class="kio_form_field"><span>Department</span><input t-att-value="addAssetForm.department" t-on-input="(ev) => this.onAssetFormInput('department', ev)"/></label>
                        </div>
                    </article>
                    <article class="kio_form_card">
                        <div class="kio_form_card_header"><i class="fa fa-user-o"/><h2>Assignment Information</h2></div>
                        <div class="kio_form_grid kio_form_grid_2">
                            <label class="kio_form_field"><span>Assign To</span><select t-att-value="addAssetForm.assignToId || &quot;&quot;" t-on-change="onAssignToChange"><option value="" t-att-selected="!addAssetForm.assignToId">Select Employee</option><t t-foreach="employeeOptions" t-as="employee" t-key="employee.id"><option t-att-value="employee.idValue" t-att-selected="(addAssetForm.assignToId || &quot;&quot;) === employee.idValue" t-esc="employee.name"/></t></select></label>
                            <label class="kio_form_field"><span>Employee ID</span><input t-att-value="addAssetForm.employeeId" readonly="readonly"/></label>
                            <label class="kio_form_field"><span>Assign Date</span><div class="kio_input_icon"><input type="date" t-att-value="addAssetForm.assignDate" t-on-click="openAssetDatePicker" t-on-input="(ev) => this.onAssetDateInput('assignDate', ev)" t-on-change="(ev) => this.onAssetDateInput('assignDate', ev)"/><i class="fa fa-calendar" t-on-click="openAssetDatePicker"/></div></label>
                            <label class="kio_form_field"><span>Expected Return Date</span><div class="kio_input_icon"><input type="date" t-att-value="addAssetForm.expectedReturnDate" t-on-click="openAssetDatePicker" t-on-input="(ev) => this.onAssetDateInput('expectedReturnDate', ev)" t-on-change="(ev) => this.onAssetDateInput('expectedReturnDate', ev)"/><i class="fa fa-calendar" t-on-click="openAssetDatePicker"/></div></label>
                        </div>
                    </article>
                    <article class="kio_form_card">
                        <div class="kio_form_card_header"><i class="fa fa-usd"/><h2>Financial Information</h2></div>
                        <div class="kio_form_grid kio_form_grid_2">
                            <label class="kio_form_field"><span>Depreciation Method <b>*</b></span><select t-att-value="addAssetForm.depreciationMethod" t-on-change="(ev) => this.onAssetFormInput('depreciationMethod', ev)"><option value="straight_line">Straight Line</option><option value="declining_balance">Declining Balance</option><option value="purchase_date">Purchase Date</option></select></label>
                            <label class="kio_form_field"><span>Useful Life (Years) <b>*</b></span><input t-att-value="addAssetForm.usefulLife" t-on-input="(ev) => this.onAssetFormInput('usefulLife', ev)"/></label>
                            <label class="kio_form_field"><span>Residual Value (৳)</span><input t-att-value="addAssetForm.residualValue" t-on-input="(ev) => this.onAssetFormInput('residualValue', ev)"/></label>
                            <label class="kio_form_field"><span>Depreciation Start Date <b>*</b></span><div class="kio_input_icon"><input type="date" t-att-value="addAssetForm.depreciationStartDate" t-on-click="openAssetDatePicker" t-on-input="(ev) => this.onAssetDateInput('depreciationStartDate', ev)" t-on-change="(ev) => this.onAssetDateInput('depreciationStartDate', ev)"/><i class="fa fa-calendar" t-on-click="openAssetDatePicker"/></div></label>
                        </div>
                    </article>
                </section>

                <section class="kio_form_card kio_additional_card">
                    <div class="kio_form_card_header"><i class="fa fa-clipboard"/><h2>Additional Information</h2></div>
                    <div class="kio_form_grid kio_additional_grid">
                        <label class="kio_form_field"><span>Supplier / Vendor</span><input t-att-value="addAssetForm.supplier" readonly="readonly"/></label>
                        <label class="kio_form_field"><span>Invoice Number</span><input t-att-value="addAssetForm.invoiceNumber" t-on-input="(ev) => this.onAssetFormInput('invoiceNumber', ev)"/></label>
                        <label class="kio_form_field"><span>PO Number</span><input t-att-value="addAssetForm.poNumber" t-on-input="(ev) => this.onAssetFormInput('poNumber', ev)"/></label>
                        <label class="kio_form_field"><span>Tags / Notes</span><textarea t-att-value="addAssetForm.tagsNotes" t-on-input="(ev) => this.onAssetFormInput('tagsNotes', ev)"><t t-esc="addAssetForm.tagsNotes"/></textarea></label>
                        <label class="kio_active_check"><input type="checkbox" t-att-checked="addAssetForm.active" t-on-change="onAssetActiveChange"/> Active</label>
                    </div>
                </section>
            </main>
        </section>
    </t>
</templates>
